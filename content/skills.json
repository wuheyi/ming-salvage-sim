  "skill_descriptions": {
    "view_state": "看核心国势、钱粮与派系态势。",
    "list_memorials": "列出本月需要皇帝过目的奏报。",
    "inspect_memorial": "追问某条奏报的细节、可信度和牵涉利益。",
    "list_regions": "查看两京十三省最危险地区、账面月税和核心警讯。",
    "inspect_region": "查看某一地区的人口、民心、动乱、天灾、人祸、田亩和税收。",
    "list_armies": "查看大明主要军队、驻扎地、维护费、补给、士气和欠饷警讯。",
    "inspect_army": "查看某支军队的驻扎地、兵种、人数、维护费、补给、士气、训练、装备和欠饷。",
    "list_personnel": "查看当前朝臣人事总表：现职、状态与任事处。",
    "inspect_minister": "查看某位官员当前现职、状态、任事处和近来牵涉诏令。",
    "inspect_personnel_changes": "查看某人或全朝最近任命、调任、罢黜、下狱、致仕、死亡等人事变动。",
    "estimate_resistance": "估算一道旨意会被谁拖、谁反弹。",
    "draft_directive": "把皇帝口谕登记为本月诏书草案，不立刻结算。",
    "draft_edict": "按奏报和政策方向拟一段可批准的圣旨文本。",
    "convene_court_debate": "召廷议定名分、分责任，慢但较稳。",
    "coordinate_ministries": "以内阁名义协调部院，适合跨衙门事项。",
    "check_treasury": "查国库、内库、本月收支和近期流水。",
    "audit_accounts": "查账册、亏空、积欠和经手人。",
    "allocate_payroll": "登记拨银、发饷、赈济、钱粮调度指令。",
    "check_military": "查军情、军心、城防和边镇奏报可信度。",
    "mobilize_troops": "登记调兵、整军、巡边、守城或出击指令。",
    "review_generals": "考核将领、军纪与虚报冒饷。",
    "estimate_project": "估算工程、工匠、材料、工期和验收。",
    "run_technical_trial": "登记火器、农政、工艺等试办指令。",
    "inner_court_inquiry": "以内廷渠道查宫中、人情、内库和旧线。",
    "transmit_edict": "传旨、催办、观察旨意是否被中途扭曲。",
    "secret_investigation": "密查账册、人物或地方隐情，快但反噬重。",
    "intimidate_obstruction": "威慑拖旨官员，短期有效但会抬高党争。",
    "audit_tax_arrears": "毕自严专长：清查积欠、实收实支、追缴亏空。",
    "front_line_plan": "袁崇焕专长：宁锦守势、军心、前线部署。",
    "strategic_review": "孙承宗专长：辽东大局复核、名分和将领评估。",
    "factory_network_probe": "魏忠贤专长：厂卫旧线、把柄、威慑与截留风险。",
    "cultivate_consort": "皇帝调教妃嫔：为其新增技能或改变性格，效果永久生效。"
  },
