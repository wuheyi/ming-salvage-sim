      {"key": "target", "label": "目标地点/战区", "type": "select", "option_source": "regions", "required": true, "placeholder": "选择地区"},
      {"key": "note", "label": "备注", "type": "textarea", "required": false, "placeholder": "补充粮饷、主将、协同等"}
